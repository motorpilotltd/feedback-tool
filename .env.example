APP_NAME="Feedback Tool"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_ADMIN_EMAIL=admin@example.com
# Password for the initial admin account created by the database seeder.
# Leave blank to have a strong password generated and printed once during seeding.
ADMIN_INITIAL_PASSWORD=

# Whether self-service registration is enabled. Off by default.
FORTIFY_REGISTER=false

# Redirect all generated URLs to https. Enable when serving over https.
APP_FORCE_HTTPS=false

CACHE_PREFIX=feedback_tool_cache_
SESSION_COOKIE=feedback_tool_session

# Microsoft Entra ID (Azure AD) single sign-on. Leave blank to disable, or
# configure via the admin settings page which overrides these defaults.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI="${APP_URL}/auth/microsoft/callback"

# Enable ONLY when this app is deployed behind Azure App Service "Easy Auth".
# It trusts the X-MS-CLIENT-PRINCIPAL-* headers Easy Auth injects to log the
# user in directly, avoiding a second in-app OAuth redirect (which loses deep
# links). Must stay false anywhere the app server is reachable without Easy
# Auth in front, otherwise those headers could be spoofed.
AZURE_EASY_AUTH=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_GB

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=feedback_tool_db
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Cache the application settings instead of querying them on every request.
# Uses the cache store above and refreshes automatically when settings save.
SETTINGS_CACHE_ENABLED=true

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_SCHEME=null
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

AUTH_PASSWORD_RESET_TOKEN_TABLE=password_resets